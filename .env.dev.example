# Compose project identity
COMPOSE_PROJECT_NAME=easy-sks-dev

# Images deployed by GitHub Actions
BACKEND_IMAGE=ghcr.io/example/easy-sks-backend:dev
FRONTEND_IMAGE=ghcr.io/example/easy-sks-frontend:dev

# Host-local ports that Caddy proxies to
BACKEND_BIND_PORT=18000
FRONTEND_BIND_PORT=13000

# Database
POSTGRES_DB=easy_sks_dev
POSTGRES_USER=easy_sks
POSTGRES_PASSWORD=change-me-dev
DATABASE_URL=postgresql+asyncpg://easy_sks:change-me-dev@db:5432/easy_sks_dev
SQLALCHEMY_ECHO=false

# Backend app config
APP_CORS_ORIGINS=https://dev.app.example.com
AUTH_COGNITO_USER_POOL_ID=eu-central-1_example
AUTH_COGNITO_REGION=eu-central-1
AUTH_COGNITO_APP_CLIENT_ID=example-dev-client-id
OPENAI_API_KEY=
OPENAI_MODEL=

# Stripe test-mode values
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PREMIUM=price_xxx
STRIPE_CHECKOUT_SUCCESS_URL=https://dev.app.example.com/account?success=true
STRIPE_CHECKOUT_CANCEL_URL=https://dev.app.example.com/account?canceled=true
STRIPE_PORTAL_RETURN_URL=https://dev.app.example.com/account

# Frontend runtime config injected at container start
RUNTIME_API_URL=https://dev.api.example.com
RUNTIME_COGNITO_DOMAIN=https://your-domain.auth.eu-central-1.amazoncognito.com
RUNTIME_COGNITO_CLIENT_ID=example-dev-client-id
RUNTIME_COGNITO_REDIRECT_URI=https://dev.app.example.com/auth/callback
RUNTIME_COGNITO_LOGOUT_URI=https://dev.app.example.com
RUNTIME_COGNITO_SCOPES=openid email profile
