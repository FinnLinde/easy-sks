# Compose project identity
COMPOSE_PROJECT_NAME=easy-sks-prod

# Images deployed by GitHub Actions
BACKEND_IMAGE=ghcr.io/example/easy-sks-backend:prod
FRONTEND_IMAGE=ghcr.io/example/easy-sks-frontend:prod

# Host-local ports that Caddy proxies to
BACKEND_BIND_PORT=28000
FRONTEND_BIND_PORT=23000

# Database
POSTGRES_DB=easy_sks_prod
POSTGRES_USER=easy_sks
POSTGRES_PASSWORD=change-me-prod
DATABASE_URL=postgresql+asyncpg://easy_sks:change-me-prod@db:5432/easy_sks_prod
SQLALCHEMY_ECHO=false

# Backend app config
APP_CORS_ORIGINS=https://app.example.com
AUTH_COGNITO_USER_POOL_ID=eu-central-1_example
AUTH_COGNITO_REGION=eu-central-1
AUTH_COGNITO_APP_CLIENT_ID=example-prod-client-id
OPENAI_API_KEY=
OPENAI_MODEL=

# Stripe live values
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PREMIUM=price_xxx
STRIPE_CHECKOUT_SUCCESS_URL=https://app.example.com/account?success=true
STRIPE_CHECKOUT_CANCEL_URL=https://app.example.com/account?canceled=true
STRIPE_PORTAL_RETURN_URL=https://app.example.com/account

# Frontend runtime config injected at container start
RUNTIME_API_URL=https://api.example.com
RUNTIME_COGNITO_DOMAIN=https://your-domain.auth.eu-central-1.amazoncognito.com
RUNTIME_COGNITO_CLIENT_ID=example-prod-client-id
RUNTIME_COGNITO_REDIRECT_URI=https://app.example.com/auth/callback
RUNTIME_COGNITO_LOGOUT_URI=https://app.example.com
RUNTIME_COGNITO_SCOPES=openid email profile
